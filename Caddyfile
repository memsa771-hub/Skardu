# Caddy listens on port 8070 (HTTP)
# Ports 80/443 are used by another service on this server.
# To make the domain work without a port number, configure your existing
# server (IIS/nginx/etc.) to reverse proxy nestopia-hotel-skardu.com -> http://127.0.0.1:8070

:8070 {
    root * C:/Sites/nestopia/dist
    file_server

    # SPA fallback — all routes serve index.html (React Router)
    try_files {path} /index.html

    # Gzip + Brotli compression
    encode zstd gzip

    # Cache static assets aggressively
    @static {
        path *.js *.css *.png *.jpg *.jpeg *.gif *.svg *.ico *.woff *.woff2 *.ttf *.mp4
    }
    header @static Cache-Control "public, max-age=31536000, immutable"

    # Cache HTML with revalidation
    @html {
        path *.html
    }
    header @html Cache-Control "no-cache"

    # Security headers
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}
