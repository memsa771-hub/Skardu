nestopia-hotel-skardu.com {
    root * C:/Sites/nestopia/dist
    file_server

    # SPA fallback — all routes serve index.html (React Router)
    try_files {path} /index.html

    # Gzip + Brotli compression
    encode zstd gzip

    # Cache static assets aggressively
    @static {
        path *.js *.css *.png *.jpg *.jpeg *.gif *.svg *.ico *.woff *.woff2 *.ttf *.mp4
    }
    header @static Cache-Control "public, max-age=31536000, immutable"

    # Cache HTML with revalidation
    @html {
        path *.html
    }
    header @html Cache-Control "no-cache"

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}

# Redirect www to non-www
www.nestopia-hotel-skardu.com {
    redir https://nestopia-hotel-skardu.com{uri} permanent
}
